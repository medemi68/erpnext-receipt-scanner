# AI provider: "anthropic", "fireworks", or "ollama"
AI_PROVIDER=anthropic

# Anthropic API key (required when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Fireworks API key (required when AI_PROVIDER=fireworks)
FIREWORKS_API_KEY=fw_...

# AI model name
# Anthropic: claude-sonnet-4-20250514, claude-haiku-4-5-20251001
# Fireworks: fireworks/kimi-k2p5, accounts/fireworks/models/llama4-scout-instruct-basic
# Ollama: qwen2.5-vl, gemma3, etc.
AI_MODEL=claude-sonnet-4-20250514

# Ollama server URL (only used when AI_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434

# Authentication tokens (must match ERPNext Invoice2Erpnext Settings)
AUTH_TOKEN_KEY=your-api-key
AUTH_TOKEN_SECRET=your-api-secret

# Server configuration
PORT=3000
LOG_LEVEL=info
MAX_FILE_SIZE_MB=20
